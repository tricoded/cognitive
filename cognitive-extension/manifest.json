{
  "manifest_version": 3,
  "name": "Cognitive AI Tracker",
  "version": "1.0",
  "description": "Tracks your AI tool usage and syncs with your Cognitive dashboard",

  "permissions": [
    "tabs",
    "storage",
    "idle",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://chatly.ai/*",
    "https://app.chatly.ai/*",
    "https://chatlyai.app/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://chat.deepseek.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "64": "icons/icon64.png",
      "96": "icons/icon96.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatly.ai/*",
        "https://app.chatly.ai/*",
        "https://chatlyai.app/*"
      ],
      "js": ["content/claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": ["content/perplexity.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content/deepseek.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "64": "icons/icon64.png",
    "96": "icons/icon96.png"
  }
}
